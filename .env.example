# 天堂图片管理器 - 敏感配置示例
# 复制本文件为 .env 并填写真实值；.env 已在 .gitignore 忽略

# HTTP/HTTPS 代理（按需配置；留空表示直连）
PROXY_HTTP=http://127.0.0.1:7897
PROXY_HTTPS=http://127.0.0.1:7897

# 下载请求头（按需覆盖）
DOWNLOAD_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) Chrome/120.0.0.0 Safari/537.36
DOWNLOAD_REFERER=https://18comic.vip/
